<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Search Results | MyIPNow</title>
<meta content="Search MyIPNow articles, guides, and tutorials." name="description"/>
<link href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' font-size='90'%3E🌐%3C/text%3E%3Ctext y='0.9em' x='28' font-size='55'%3E📍%3C/text%3E%3C/svg%3E" rel="icon"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg-color:#f7f8f9; --card-bg:#ffffff; --text-primary:#1e293b; --text-secondary:#64748b;
    --accent-color:#4f46e5; --hide-ip-color:#10b981; --card-shadow:0 10px 30px rgba(0,0,0,0.08);
    --border-radius:16px;
  }
  body{font-family:'Inter',sans-serif;background:var(--bg-color);margin:0;padding:0;color:var(--text-primary);line-height:1.6;}
  .container{max-width:900px;margin:0 auto;padding:1rem;}
  .site-header{background:var(--card-bg);padding:1rem;margin-bottom:2rem;border-radius:var(--border-radius);box-shadow:var(--card-shadow);}
  .header-top{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;padding-bottom:1rem;border-bottom:1px solid #e2e8f0;}
  .logo{font-size:1.5rem;font-weight:700;color:var(--text-primary);text-decoration:none;}
  .search-form{display:flex;flex-grow:1;max-width:400px;}
  .search-form input{width:100%;padding:.75rem 1rem;border:1px solid #e2e8f0;border-radius:8px 0 0 8px;font-size:.9rem;outline-color:var(--accent-color);}
  .search-form button{padding:.75rem 1rem;border:none;background:var(--hide-ip-color);color:#fff;border-radius:0 8px 8px 0;cursor:pointer;font-weight:500;transition:background-color .2s ease;}
  .search-form button:hover{background:#059669;}
  .category-nav{padding-top:1rem;}
  .category-nav ul{
    display:flex;gap:1.5rem;list-style:none;margin:0;padding:0;align-items:center;
    overflow-x:auto;white-space:nowrap;justify-content:center !important;
  }
  .category-nav a{text-decoration:none;color:var(--text-primary);font-size:.9rem;font-weight:500;transition:color .2s ease;}
  .category-nav a:hover{color:var(--accent-color);}
  .page-header{background:var(--card-bg);padding:2rem;border-radius:var(--border-radius);box-shadow:var(--card-shadow);margin-bottom:2rem;text-align:center;}
  .page-header h1{font-size:2.5rem;color:var(--text-primary);margin:0 0 .5rem 0;}
  .page-header p{font-size:1rem;color:var(--text-secondary);margin:0;}
  .article-list .article-item{background:var(--card-bg);margin-bottom:1.5rem;border-radius:var(--border-radius);box-shadow:var(--card-shadow);padding:1.5rem 2rem;transition:transform .2s ease, box-shadow .2s ease;}
  .article-list .article-item:hover{transform:translateY(-5px);box-shadow:0 15px 35px rgba(0,0,0,0.1);}
  .article-item h2{margin-top:0;}
  .article-item h2 a{text-decoration:none;color:var(--text-primary);font-size:1.5rem;}
  .article-item h2 a:hover{color:var(--accent-color);}
  .article-excerpt{color:var(--text-secondary);font-size:1rem;}
  .read-more{display:inline-block;margin-top:1rem;color:var(--accent-color);text-decoration:none;font-weight:600;}
  .pagination{display:flex;justify-content:center;gap:1rem;align-items:center;margin-top:2rem;padding-bottom:2rem;}
  .pagination a,.pagination span{padding:.75rem 1rem;border-radius:8px;text-decoration:none;color:var(--text-primary);background:var(--card-bg);box-shadow:0 4px 10px rgba(0,0,0,0.05);}
  .pagination a:hover{background:var(--accent-color);color:#fff;}
  .pagination .current{background:var(--accent-color);color:#fff;font-weight:600;}
  .footer{text-align:center;padding:2rem 1rem;margin:2rem auto 0;background:#fff;border-radius:16px;box-shadow:var(--card-shadow);}
  .footer-nav{display:flex;justify-content:center;flex-wrap:wrap;gap:1rem 1.5rem;list-style:none;padding:0;margin:0 0 1rem 0;}
  .footer-nav a{color:var(--text-secondary);text-decoration:none;font-size:.9rem;transition:color .2s ease;}
  .footer-nav a:hover{color:var(--accent-color);}
  .footer-copyright{font-size:.85rem;color:var(--text-secondary);}
  mark{background:yellow;padding:0 2px;}
  @media (max-width:768px){
    .header-top{flex-direction:column;align-items:flex-start;}
    .search-form{width:100%;max-width:none;}
    .category-nav ul{overflow-x:auto;padding-bottom:10px;white-space:nowrap;justify-content:center !important;}
  }
</style>

</head>
<body>
<div class="container">
  <header class="site-header">
    <div class="header-top">
      <a class="logo" href="/">🌐 MyIPNow</a>
      <form action="/search.html" class="search-form" method="get">
  <input aria-label="Search articles" name="q" placeholder="Search..." type="search"/>
  <button type="submit">Search</button>
</form>
    </div>
    <nav aria-label="Article Categories" class="category-nav">
      <ul>
        <li><a href="/online-safety/">Online Safety</a></li>
        <li><a href="/online-privacy/">Online Privacy</a></li>
        <li><a href="/networking/">Networking</a></li>
        <li><a href="/ip-addresses/">IP Addresses</a></li>
        <li><a href="/home-computing/">Home Computing</a></li>
        <li><a href="/general-topics/">General Topics</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <header class="page-header">
      <h1 id="ph-title">Search Results</h1>
      <p id="ph-sub">Find articles, guides, and tutorials across MyIPNow.</p>
    </header>

    <div id="results" class="article-list"></div>
    <nav aria-label="Page navigation" class="pagination" id="pagination"></nav>
  </main>

  <footer class="footer">
    <ul class="footer-nav">
      <li><a href="/about.html">About</a></li>
      <li><a href="/contact.html">Contact</a></li>
      <li><a href="/privacy-policy.html">Privacy Policy</a></li>
      <li><a href="/terms-of-use.html">Terms of Use</a></li>
      <li><a href="/affiliate-disclosure.html">Affiliate Disclosure</a></li>
    </ul>
    <div class="footer-copyright">© 2025 myipnow. All Rights Reserved.</div>
  </footer>
</div>

<script>
  // ——— helpers
  const qs = new URLSearchParams(location.search);
  const QUERY = (qs.get("q") || "").trim();
  const PAGE  = Math.max(1, parseInt(qs.get("page") || "1", 10));
  const PER_PAGE = 10;

  function escHtml(s){return s.replace(/[&<>"]/g,m=>({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[m]));}

  function wordsToRegex(words){
    const toks = words
      .split(/\s+/)
      .filter(w => w.length > 2) // ignore tiny words
      .map(w => w.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"));
    if(!toks.length) return null;
    return new RegExp("(" + toks.join("|") + ")", "gi");
  }

  function makeSnippet(text, query){
    const clean = text.replace(/\s+/g,' ').trim();
    if(!query) return escHtml(clean.slice(0,180)) + (clean.length>180?'…':'');
    const toks = query.split(/\s+/).filter(w => w.length>2);
    let hit = -1;
    for(const t of toks){
      const i = clean.toLowerCase().indexOf(t.toLowerCase());
      if(i !== -1){ hit = i; break; }
    }
    let start = hit === -1 ? 0 : Math.max(0, hit - 80);
    let end   = Math.min(clean.length, start + 220);
    let snip  = clean.slice(start, end);
    if(start>0) snip = "…" + snip;
    if(end<clean.length) snip += "…";
    const rx = wordsToRegex(query);
    return rx ? escHtml(snip).replace(rx, "<mark>$1</mark>") : escHtml(snip);
  }

  function highlightTitle(title, query){
    const rx = wordsToRegex(query || "");
    return rx ? escHtml(title).replace(rx, "<mark>$1</mark>") : escHtml(title);
  }

  function renderPagination(total, page, q){
    const el = document.getElementById("pagination");
    el.innerHTML = "";
    const pages = Math.ceil(total / PER_PAGE);
    if(pages <= 1) return;

    function link(p,label){ return `<a href="?q=${encodeURIComponent(q)}&page=${p}">${label}</a>`; }
    function curr(p){ return `<span class="current">${p}</span>`; }

    if(page>1) el.innerHTML += link(page-1,"← Previous");

    // smart range with ellipses
    const out = [];
    const push = v => out.push(v);
    const addEll = () => out.push("<span>…</span>");

    if(pages <= 7){
      for(let i=1;i<=pages;i++) push(i===page?curr(i):link(i,i));
    }else{
      push(page===1?curr(1):link(1,1));
      if(page>3) addEll();
      const start = Math.max(2, page-1);
      const end   = Math.min(pages-1, page+1);
      for(let i=start;i<=end;i++) push(i===page?curr(i):link(i,i));
      if(page < pages-2) addEll();
      push(page===pages?curr(pages):link(pages,pages));
    }

    el.innerHTML += out.join(" ");
    if(page<pages) el.innerHTML += link(page+1,"Next →");
  }

  // ——— main
  document.addEventListener("DOMContentLoaded", () => {
    const phTitle = document.getElementById("ph-title");
    const phSub   = document.getElementById("ph-sub");
    const resultsBox = document.getElementById("results");

    if(QUERY){
      phTitle.innerHTML = `Search Results for “${escHtml(QUERY)}”`;
      phSub.textContent = "Find articles, guides, and tutorials across MyIPNow.";
    }else{
      phTitle.textContent = "Search Results";
      phSub.textContent = "Type a query in the search bar.";
    }

    fetch("/search_index.json")
      .then(r => r.json())
      .then(docs => {
        // build lunr index
        const idx = lunr(function () {
          this.ref('id');
          this.field('title');
          this.field('content');
          docs.forEach(function (doc) { this.add(doc) }, this);
        });

        const hits = QUERY ? idx.search(QUERY) : [];
        if(!QUERY){
          resultsBox.innerHTML = `<p class="article-excerpt">Enter a keyword above and press Search.</p>`;
          return;
        }
        if(hits.length === 0){
          resultsBox.innerHTML = `<p class="article-excerpt">No results found for <strong>${escHtml(QUERY)}</strong>.</p>`;
          return;
        }

        // render page of results
        const start = (PAGE-1)*PER_PAGE;
        const pageHits = hits.slice(start, start+PER_PAGE);

        resultsBox.innerHTML = pageHits.map(h => {
          const item = docs.find(d => d.id == h.ref) || {title:"",url:"#",content:""};
          return `
            <article class="article-item">
              <h2><a href="${item.url}">${highlightTitle(item.title, QUERY)}</a></h2>
              <p class="article-excerpt">${makeSnippet(item.content || "", QUERY)}</p>
              <a class="read-more" href="${item.url}">Read More →</a>
            </article>`;
        }).join("");

        renderPagination(hits.length, PAGE, QUERY);
      })
      .catch(() => {
        resultsBox.innerHTML = `<p class="article-excerpt">Search is temporarily unavailable.</p>`;
      });
  });
</script>
</body>
</html>
