<script>
  var documents = [
    { "id": 1, "title": "About", "url": "/about.html", "content": "Learn more about MyIPNow" },
    { "id": 2, "title": "Contact", "url": "/contact.html", "content": "Get in touch with us" },
    { "id": 3, "title": "Privacy Policy", "url": "/privacy-policy.html", "content": "Privacy Policy" },
    { "id": 4, "title": "Terms of Use", "url": "/terms-of-use.html", "content": "Terms and conditions" },
    { "id": 5, "title": "Networking", "url": "/networking/", "content": "Networking basics and guides" },
    { "id": 6, "title": "Online Safety", "url": "/online-safety/", "content": "Stay safe online" }
  ];

  var idx = lunr(function () {
    this.ref('id');
    this.field('title');
    this.field('content');
    documents.forEach(function (doc) { this.add(doc) }, this);
  });

  var input = document.getElementById('search-input');
  var resultsBox = document.getElementById('search-results');

  if (input) {
    input.addEventListener('input', function () {
      var query = input.value.trim();
      if (query.length < 2) {
        resultsBox.style.display = "none";
        return;
      }
      var results = idx.search(query);
      resultsBox.innerHTML = "";
      if (results.length > 0) {
        resultsBox.style.display = "block";
        results.forEach(function (res) {
          var item = documents.find(d => d.id == res.ref);
          resultsBox.innerHTML += `
            <div class="result">
              <a href="${item.url}">${item.title}</a>
            </div>`;
        });
      } else {
        resultsBox.style.display = "block";
        resultsBox.innerHTML = "<div class='result'>No results found.</div>";
      }
    });
  }
</script>

